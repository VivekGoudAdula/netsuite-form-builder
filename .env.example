# Frontend Configuration (Vite)
VITE_API_URL="http://localhost:8000/api"
FRONTEND_URL="http://localhost:3000"

# Backend Configuration
MONGO_URI=Your_Mongo_URL
DB_NAME=Your_DB_Name
JWT_SECRET=Your_JWT_Secret
JWT_EXPIRE_MINUTES=60

SMTP_EMAIL=Your_Mail_ID
SMTP_PASSWORD=Your_Password

# NetSuite OAuth 1.0 (HMAC-SHA256) — values come from NetSuite one-time integration setup.
# Base host for RESTlets (no query string here; script/deploy are separate env vars).
NETSUITE_BASE_URL=https://6738288-sb1.restlets.api.netsuite.com
NETSUITE_REALM=6738288_SB1

# Employee GET / submission POST RESTlets
NETSUITE_GET_SCRIPT=customscript_rg_get_rest_pai
NETSUITE_POST_SCRIPT=customscript_rg_post_rest_pai
NETSUITE_DEPLOY=1

# Token credentials (use NETSUITE_ACCESS_TOKEN; NETSUITE_TOKEN is a legacy fallback)
NETSUITE_CONSUMER_KEY=YOUR_KEY
NETSUITE_CONSUMER_SECRET=YOUR_SECRET
NETSUITE_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
NETSUITE_TOKEN=YOUR_TOKEN
NETSUITE_TOKEN_SECRET=YOUR_TOKEN_SECRET

# ── Per-entity script IDs below are used ONLY for first-time seed into MongoDB
# (collection: netsuite_datasources). After seed, configure connectors in the UI.
# Account-level OAuth credentials above are the only required .env NetSuite vars.

# Currency RESTlet: GET {NETSUITE_BASE_URL}/app/site/hosting/restlet.nl?script=...&deploy=...
NETSUITE_CURRENCY_SCRIPT=customscript_rg_restapi_currency_fetch
NETSUITE_CURRENCY_DEPLOY=1

# HSN Code RESTlet: GET {NETSUITE_BASE_URL}/app/site/hosting/restlet.nl?script=...&deploy=...
NETSUITE_HSN_SCRIPT=customscript_rg_restapi_hsncode_fetch
NETSUITE_HSN_DEPLOY=1

# Location RESTlet: GET {NETSUITE_BASE_URL}/app/site/hosting/restlet.nl?script=...&deploy=...
NETSUITE_LOCATION_SCRIPT=customscript_rg_restapi_location_fetch
NETSUITE_LOCATION_DEPLOY=1

# India Tax Nature RESTlet (live lookup — not stored in MongoDB)
NETSUITE_TAX_NATURE_SCRIPT=customscript_rg_restapi_tax_nature_fetch
NETSUITE_TAX_NATURE_DEPLOY=1

# Department RESTlet (live lookup — not stored in MongoDB)
NETSUITE_DEPARTMENT_SCRIPT=customscript_rg_restapi_department_fetch
NETSUITE_DEPARTMENT_DEPLOY=1

# Class RESTlet (live lookup — not stored in MongoDB)
NETSUITE_CLASS_SCRIPT=customscript_rg_restapi_class_fetch
NETSUITE_CLASS_DEPLOY=1

# Account RESTlet (live lookup — not stored in MongoDB)
NETSUITE_ACCOUNT_SCRIPT=customscript_rg_restapi_account_fetch
NETSUITE_ACCOUNT_DEPLOY=1

# Item RESTlet (live lookup — not stored in MongoDB)
NETSUITE_ITEM_SCRIPT=customscript_rg_restapi_item_fetch
NETSUITE_ITEM_DEPLOY=1

# Vendor RESTlet (live lookup — not stored in MongoDB)
NETSUITE_VENDOR_SCRIPT=customscript_rg_restapi_vendor_fetch
NETSUITE_VENDOR_DEPLOY=1

# Customer RESTlet (live lookup — not stored in MongoDB)
NETSUITE_CUSTOMER_SCRIPT=customscript_rg_restapi_customer_fetch
NETSUITE_CUSTOMER_DEPLOY=1